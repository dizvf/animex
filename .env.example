# ── Next.js (Vercel) ──────────────────────────────────────────
# Railway proxy URL (set after deploying server/)
RAILWAY_API_URL=https://your-project.up.railway.app

# Anify API (if using their public API directly instead of Railway)
ANIFY_API_URL=https://api.anify.tv
ANIFY_API_KEY=

# ── Railway server ────────────────────────────────────────────
# Set these in Railway environment variables dashboard:
#
# ANIFY_API_URL=https://api.anify.tv
# ANIFY_API_KEY=your_key_if_needed
# ALLOWED_ORIGIN=https://your-vercel-app.vercel.app
# PORT=3001  (Railway sets this automatically)
